# ===================================
# NoRadar Content Engine - Configuration
# ===================================
# Copier ce fichier vers .env et remplir les valeurs

# === Gemini API (Scripts) ===
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=sk-ant-...

# === Google Cloud TTS (Voix) ===
# Chemin vers le fichier service account JSON
GOOGLE_APPLICATION_CREDENTIALS=credentials/service-account.json

# === Pexels API (Vidéos de fond - GRATUIT) ===
# Créer un compte sur https://www.pexels.com/api/ et récupérer la clé
PEXELS_API_KEY=your_pexels_api_key_here

# === Google Drive (Stockage - optionnel) ===
GDRIVE_FOLDER_ID=your_folder_id_here

# === ElevenLabs (Voix alternative - optionnel) ===
# Créer un compte sur https://elevenlabs.io et récupérer la clé
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# === Redis (deduplication scripts) ===
# REDIS_URL=redis://localhost:6379

# === Analytics TikTok + Instagram + Telegram (rapport hebdo) ===
TIKTOK_ACCESS_TOKEN=your_tiktok_business_token_here
INSTAGRAM_ACCESS_TOKEN=your_instagram_graph_api_token_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ADMIN_TELEGRAM_CHAT_ID=your_admin_chat_id_here

# === Options avancées (valeurs par défaut OK) ===
# TTS_VOICE_NAME=fr-FR-Wavenet-D
# TTS_SPEAKING_RATE=1.1
# VIDEO_WIDTH=1080
# VIDEO_HEIGHT=1920
# VIDEO_FPS=30
